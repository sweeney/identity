# /etc/identity/env
# This file must be owned by root with mode 600:
#   sudo chown root:root /etc/identity/env
#   sudo chmod 600 /etc/identity/env

JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Port (default 8181)
# PORT=8181

# Database path (default: identity.db in working directory)
# DB_PATH=/var/lib/identity/identity.db

# Optional: initial admin credentials for first run only.
# If not set, a random password is written to initial-password.txt in the working directory.
# These are ignored after the first user is created.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me

# Optional: previous JWT secret for zero-downtime key rotation
# JWT_SECRET_PREV=

# Proxy trust: set to "cloudflare" to trust CF-Connecting-IP header for client IPs.
# Leave empty/unset (default) to always use RemoteAddr — safe when not behind Cloudflare.
# TRUST_PROXY=cloudflare

# Site name: shown in admin nav, OAuth login pages, page titles (default: Identity)
# SITE_NAME=id.swee.net

# WebAuthn / Passkeys (optional — disabled if WEBAUTHN_RP_ID is not set)
# Use the parent domain so passkeys work across subdomains and native apps.
# The RP ID is permanent — changing it invalidates all existing passkeys.
# WEBAUTHN_RP_ID=swee.net
# WEBAUTHN_RP_ORIGINS=https://id.swee.net

# CORS origins: comma-separated list of allowed origins for API CORS.
# These are also merged into WebAuthn allowed origins automatically.
# CORS_ORIGINS=https://app.swee.net

# Cloudflare R2 backup (optional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
